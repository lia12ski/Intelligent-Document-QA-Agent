# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# OCR provider: paddleocr | tesseract
OCR_PROVIDER=paddleocr

# Parser provider: local | mineru
# Streamlit Demo will default to MinerU when MINERU_API_KEY is configured.
PARSER_PROVIDER=local

# MinerU settings, only needed when PARSER_PROVIDER=mineru
MINERU_BASE_URL=https://mineru.net
MINERU_API_KEY=
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL_SECONDS=5
MINERU_MAX_WAIT_SECONDS=600

# LLM provider: deepseek | openai | ollama | mock
LLM_PROVIDER=mock
LLM_TIMEOUT_SECONDS=60

# DeepSeek settings, only needed when LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible settings, only needed when LLM_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Also supported aliases: LLM_BASE_URL, LLM_API_KEY, LLM_MODEL

# Ollama settings, only needed when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Embedding
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Optional local dependency path, e.g. C:\path\to\.venv\Lib\site-packages
EXTRA_SITE_PACKAGES=
DENSE_RETRIEVAL_ENABLED=true
DENSE_BACKEND=faiss
DENSE_FAIL_OPEN=true

# QA self-check thresholds. RRF scores are rank-fusion scores, not 0-1 confidence.
RETRIEVAL_MIN_SCORE=0.01
DENSE_MIN_SCORE=0.4
# Backward-compatible alias; prefer RETRIEVAL_MIN_SCORE in new configs.
ANSWER_MIN_SCORE=0.01

# Index and target-document validation
REQUIRE_INDEX_MANIFEST=true
TARGET_VALIDATION_ENABLED=true
TARGET_DOCUMENT_KEYWORDS=中信证券,财务报表,2025 半年度报告
INLINE_TABLE_KEYWORDS=项目,要求,账面价值,被投资单位名称,本期增加,本期减少,合计,金额,到期日,金融负债,即期偿还,减值准备
DOMAIN_FOCUS_TERMS=账面价值,金额,合计,到期日,被投资单位名称,金融负债,财务报表,期间
QUERY_TABLE_TERMS=表格,对应,项目,账面价值,合计,金额,到期日,被投资单位
QUERY_NUMERIC_TERMS=多少,数值,比例,金额,余额
QUERY_DEFINITION_TERMS=是什么,定义,含义,指什么,期间
QUERY_GENERIC_PHRASES=这个标准,这个,标准,请问,文档中,文档里,是否,规定了
QUERY_OCR_REPLACEMENTS=价植=>价值,价直=>价值,帐面=>账面,帐戸=>账户,賬面=>账面,金額=>金额,負债=>负债,财務=>财务
GENERIC_AMOUNT_EXPANSION=金额 合计 账面价值 金融负债

# Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
INDEX_DIR=data/index
